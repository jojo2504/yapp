# ============================================
# PostgreSQL
# ============================================
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# Set SUPABASE_DB_URL to connect to a Supabase (or any external) PostgreSQL instance.
# When set, all DB_* variables below are ignored.
# Format: postgresql://user:password@host:port/dbname?sslmode=require
SUPABASE_DB_URL=

# Ces variables sont utilisées par le backend Go (fallback si SUPABASE_DB_URL n'est pas défini)
DB_HOST=postgres
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=yapp
DB_SSLMODE=disable

# ============================================
# Redis
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# JWT (à changer en production !)
# ============================================
JWT_SECRET=change-this-secret-in-production-please
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=168h

# ============================================
# Environment
# ============================================
ENV=development
