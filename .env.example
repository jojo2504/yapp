# ============================================
# PostgreSQL
# ============================================
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# Ces variables sont utilisées par le backend Go
DB_HOST=postgres
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=yapp
DB_SSLMODE=disable

# ============================================
# Redis
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# JWT (à changer en production !)
# ============================================
JWT_SECRET=change-this-secret-in-production-please
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=168h

# ============================================
# Environment
# ============================================
ENV=development
